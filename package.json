{
    "name": "expense-tracker",
    "version": "1.0.0",
    "description": "Flask-based expense tracking application with npm tooling",
    "scripts": {
        "dev": "python app.py",
        "start": "python app.py",
        "install-python": "pip install -r requirements.txt",
        "build:css": "postcss static/css/style.css -o static/css/style.min.css",
        "build:js": "esbuild static/js/script.js --bundle --minify --outfile=static/js/script.min.js",
        "build": "npm run build:css && npm run build:js",
        "watch:css": "postcss static/css/style.css -o static/css/style.min.css --watch",
        "watch:js": "esbuild static/js/script.js --bundle --outfile=static/js/script.min.js --watch",
        "watch": "npm-run-all --parallel watch:css watch:js",
        "lint:js": "eslint static/js/**/*.js",
        "lint:css": "stylelint static/css/**/*.css",
        "lint": "npm run lint:js && npm run lint:css",
        "format": "prettier --write \"static/**/*.{js,css,html}\""
    },
    "keywords": [
        "flask",
        "expense-tracker",
        "python"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "esbuild": "^0.20.0",
        "postcss": "^8.4.35",
        "postcss-cli": "^11.0.0",
        "autoprefixer": "^10.4.17",
        "cssnano": "^6.0.3",
        "eslint": "^8.56.0",
        "stylelint": "^16.2.0",
        "prettier": "^3.2.5",
        "npm-run-all": "^4.1.5"
    },
    "dependencies": {}
}